# 複製本檔為 .env 並填入實際值（.env 已被 .gitignore）
# 環境變數會覆蓋 config/config_<ENV>.yaml 的同名設定（點號 → 底線）
# 容器部署時可只用環境變數，不放實體 yaml

# 環境設定（prod / dev），決定載入哪份 config_<ENV>.yaml
ENV=prod

# === Demo 專用（正式環境務必移除或設為 false）===
# 跳過 IP 白名單防火牆，讓任何來源都能存取
DEMO_MODE=true
# RUN_MIGRATE=true 時是否一併灌入 demo 業務假資料（商品/客戶/進銷存）
SEED_DEMO=true

# 伺服器
SERVER_WEBSITE_PORT=8002
SERVER_MODE=release
SERVER_ALLOWEDORIGINS=http://localhost:5207
SERVER_LOGS_FILEPATH=storage/logs
SERVER_LOGS_FILENAME=access
SERVER_JWTKEY=<YOUR_BASE64_JWT_KEY>
SERVER_SECURITY_BCRYPTCOST=12
SERVER_SECURITY_ALLOWEDOFFICEIP=
# 首次 RUN_MIGRATE 時建立的預設管理員（admin）密碼 —— 登入就用這組
SERVER_SEEDADMINPASSWORD=demo1234

# PostgreSQL 主庫
DATABASE_POSTGRES_MASTER_HOSTNAME=<DB_HOST>
DATABASE_POSTGRES_MASTER_USERNAME=<DB_USER>
DATABASE_POSTGRES_MASTER_PASSWORD=<DB_PASSWORD>
DATABASE_POSTGRES_MASTER_DBNAME=<DB_NAME>
DATABASE_POSTGRES_MASTER_PORT=5432

# PostgreSQL 從庫
DATABASE_POSTGRES_SLAVE_HOSTNAME=<DB_HOST>
DATABASE_POSTGRES_SLAVE_USERNAME=<DB_USER>
DATABASE_POSTGRES_SLAVE_PASSWORD=<DB_PASSWORD>
DATABASE_POSTGRES_SLAVE_DBNAME=<DB_NAME>
DATABASE_POSTGRES_SLAVE_PORT=5432

# Redis
REDIS_HOST=<REDIS_HOST>
REDIS_PORT=6379
REDIS_PASSWORD=<REDIS_PASSWORD>
REDIS_DB=0
REDIS_POOLSIZE=20

# MinIO 檔案儲存
MINIO_ENDPOINT=<MINIO_ENDPOINT>
MINIO_ACCESSKEY=<MINIO_ACCESS_KEY>
MINIO_SECRETKEY=<MINIO_SECRET_KEY>
MINIO_BUCKET=<MINIO_BUCKET>
MINIO_USESSL=true

# 首次啟動建立資料表（謹慎使用）
# RUN_MIGRATE=true
